# Prisma runtime database URL (Supabase Postgres)
# 형식 예시:
# postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?schema=public
DATABASE_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?schema=public"

# Supabase Storage (server-side signed upload URL 발급용)
NEXT_PUBLIC_SUPABASE_URL="https://<PROJECT_REF>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<SUPABASE_SERVICE_ROLE_KEY>"
SUPABASE_STORAGE_BUCKET="lecture-materials"

# OpenAI (STT + LLM 후보정)
OPENAI_API_KEY="<OPENAI_API_KEY>"
WORKER_STT_MODEL="gpt-4o-mini-transcribe"
WORKER_LLM_MODEL="gpt-4o-mini"
